# LLM API (OpenAI-compatible)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4-turbo

# Embedding model for CNGE coreference & CGCA gating
EMBEDDING_MODEL=all-MiniLM-L6-v2

# CNGE coreference (optional)
COREF_SIMILARITY_THRESHOLD=0.85

# CausOpt MCTS parameters (optional overrides)
MCTS_ITERATIONS=10000
MCTS_TIME_BUDGET_SEC=300
MCTS_EXPLORATION_CONSTANT=0.5
MCTS_MAX_BRANCHING=10
CAUSOPT_MAX_SCENES=50
CAUSOPT_MIN_SCENES_PER_ACT=3
