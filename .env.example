# LLM API (OpenAI-compatible)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4-turbo

# LLM request timeout in seconds (increase for slow providers like DeepSeek)
OPENAI_TIMEOUT=300

# HuggingFace mirror (set for Chinese mainland users when huggingface.co is blocked)
HF_ENDPOINT=https://hf-mirror.com

# Embedding model for CNGE coreference & CGCA gating
#   all-MiniLM-L6-v2              → sentence-transformers (local, default)
#   openai/text-embedding-3-small → OpenAI API (需 API key, 见下方)
#   gemini/text-embedding-004     → Google Gemini API (需 GEMINI_API_KEY)
#
# 注意: DeepSeek 不提供 embeddings API，deepseek/... 不可用
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Embedding API credentials (仅当使用 openai/... embedder 时需要)
# 若与 LLM 共用同一 key，可省略，自动回退到 OPENAI_API_KEY
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_BASE_URL=https://api.openai.com/v1

# Google Gemini API key (仅当使用 gemini/... embedder 时需要)
# GEMINI_API_KEY=your_key_here

# CNGE coreference (optional)
COREF_SIMILARITY_THRESHOLD=0.85

# CausOpt MCTS parameters (optional overrides)
MCTS_ITERATIONS=10000
MCTS_TIME_BUDGET_SEC=300
MCTS_EXPLORATION_CONSTANT=0.5
MCTS_MAX_BRANCHING=10
CAUSOPT_MAX_SCENES=50
CAUSOPT_MIN_SCENES_PER_ACT=3

# Demo video TTS (optional, for scripts/demo_video.py)
# SiliconFlow（国内可用，直接用 OpenAI 客户端）:
#   TTS_BASE_URL=https://api.siliconflow.cn/v1
#   TTS_API_KEY=你的硅基流动 API Key
#   TTS_MODEL=fishaudio/fish-speech-1.5
#   TTS_VOICE=anna    # 硅基流动的 voice 为 model:voice 格式，也可设 alloy/alex
